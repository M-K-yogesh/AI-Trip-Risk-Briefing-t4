PORT=5000
JWT_SECRET=your_jwt_secret_key_here

# PostgreSQL Connection (for local development)
# For Render/cloud deployment, use DATABASE_URL instead
DATABASE_URL=postgresql://user:password@host:port/dbname

# Or use individual variables for local development:
PG_HOST=127.0.0.1
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=your_postgres_password
PG_DATABASE=trip_risk_db

# Set to true if your PostgreSQL provider requires SSL (Neon, Aiven, Supabase, etc.)
PG_SSL=false

# AI Providers API Keys
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
